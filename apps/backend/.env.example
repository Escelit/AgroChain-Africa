# ============================================================
# AgroChain Africa — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Run ./setup-dev.sh to do this automatically.
#
# REQUIRED to run locally (minimum set):
#   DATABASE_URL, REDIS_URL, JWT_SECRET, STELLAR_NETWORK
#
# Everything else has mock/stub fallbacks for local dev.
# ============================================================

# App
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:4200

# Database — docker compose up -d postgres redis starts these
DATABASE_URL=postgresql://agrochain:password@localhost:5432/agrochain_db
REDIS_URL=redis://localhost:6379

# JWT — any random string works for local dev
JWT_SECRET=change-me-use-setup-dev-sh
JWT_EXPIRY=7d

# Stellar
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs — leave blank until you deploy contracts (see docs/stellar-integration.md)
# The app runs with mock fallbacks when these are empty.
HARVEST_TOKEN_CONTRACT_ID=
ESCROW_CONTRACT_ID=
CREDIT_SCORE_CONTRACT_ID=
LOAN_CONTRACT_ID=

# Platform signer — generate with: stellar keys generate --network testnet platform
PLATFORM_SIGNER_SECRET=

# Oracle signer — generate with: stellar keys generate --network testnet oracle
ORACLE_PUBLIC_KEY=
ORACLE_SIGNER_SECRET=

# Oracle webhook API key — any string for local dev
ORACLE_API_KEY=dev-oracle-api-key

# Mobile money anchors (optional — withdrawal flow is stubbed without these)
MPESA_ANCHOR_URL=https://anchor.mpesa.example.com
MTN_MOMO_ANCHOR_URL=https://anchor.mtnmomo.example.com
FLUTTERWAVE_ANCHOR_URL=https://anchor.flutterwave.example.com

# Africa's Talking SMS (optional — logs to console without these)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# Sentinel Hub NDVI (optional — returns mock forecast without these)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
NASA_HARVEST_API_KEY=
